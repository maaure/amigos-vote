# Copie este arquivo para .env.local e preencha com seus valores.
# NUNCA comite .env.local.

# =================================================================
# NEXTAUTH_SECRET
# =================================================================
# Chave secreta para assinar/criptar tokens, sessions e cookies.
# Necessária em produção. Gere com: openssl rand -base64 32
NEXTAUTH_SECRET=<32bytes_base64_key>

# =================================================================
# POSTGRESQL (DOCKER COMPOSE)
# =================================================================
# Variáveis usadas pelo docker-compose.yml para o container do banco.
POSTGRES_USER=inimigo-user
POSTGRES_PASSWORD=inimigo-pass
POSTGRES_DB=inimigo-db
DB_ADDRESS=db

# =================================================================
# AUTENTICAÇÃO
# =================================================================
GITHUB_ID=<seu-github-id>
GITHUB_SECRET=<seu-github-secret>

# Chave para proteger rotas de CRON
CRON_SECRET_KEY=<sua-cron-key-segura>