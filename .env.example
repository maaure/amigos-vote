# Docker Compose + Next.js (dev e prod)
# Copie para .env e preencha. NUNCA comite o .env.

POSTGRES_USER=inimigo-user
POSTGRES_PASSWORD=inimigo-pass
POSTGRES_DB=inimigo-db
DB_ADDRESS=db

# Prefixo do basePath do Next (build time) e do axios. Vazio em dev.
NEXT_PUBLIC_BASE_PATH=/tribunal-do-dia

# URL COMPLETA até /api/auth (NextAuth exige a rota inteira).
# Dev local:  http://localhost:3000/api/auth
NEXTAUTH_URL=http://localhost:3000/api/auth

# Domínio público usado pelo Caddyfile (apenas em produção).
DOMAIN=localhost

NEXTAUTH_SECRET=<gere-com-openssl-rand-base64-32>
GITHUB_ID=<seu-github-id>
GITHUB_SECRET=<seu-github-secret>
GOOGLE_ID=<seu-google-id>
GOOGLE_SECRET=<seu-google-secret>
